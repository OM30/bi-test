	partition d_subtarefa_descr = m
		mode: import
		source =
				let
				    Fonte = MySQL.Database("10.20.16.61", "glpi", [ReturnSingleDatabase=true, Query="SELECT #(lf)    tt.tickets_id,#(lf)    tt.date,#(lf)#(lf)    REGEXP_REPLACE(#(lf)        REPLACE(#(lf)            REPLACE(#(lf)                REPLACE(#(lf)                    REPLACE(tt.content,#(lf)                        '&#60;', '<'),#(lf)                    '&#62;', '>'),#(lf)                '&lt;', '<'),#(lf)            '&gt;', '>'),#(lf)        '<[^>]*>',#(lf)        ''#(lf)    ) AS descricao_limpa#(lf)#(lf)FROM glpi_tickettasks tt"])
				in
				    Fonte

