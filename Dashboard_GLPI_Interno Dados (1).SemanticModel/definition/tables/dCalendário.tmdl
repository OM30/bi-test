	partition dCalendário = calculated
		mode: import
		source =
				ADDCOLUMNS(
				    	CALENDAR(DATE(2018,01,01),TODAY()),
				        	"ANO", YEAR([Date]),
				        	"MÊS", UPPER(FORMAT([Date], "mmmm")),
				        	"MÊS ABREVIADO", UPPER(FORMAT([Date], "mmm")),
				        	"MÊS NUM", FORMAT([Date], "MM"),
						    "DIA MÊS", DAY([Date]),
				        	"DIA SEMANA", UPPER(FORMAT([Date], "DDDD")),
				        	"DIA SEMANA ABREVIADO", UPPER(FORMAT([Date], "DDD")),
				        	"DIA SEMANA NUM", WEEKDAY([Date]),
				        	"SEMANA ANO NUM", WEEKNUM([Date]),
				        	"MÊSANO", UPPER(FORMAT([Date], "MMM-YYYY")),
				        	"MÊSANO NUM", UPPER(FORMAT([Date], "YYYYMM")))

	annotation PBI_Id = 78b7ce81cd1f47759ec2ba7edc4311b3

